<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Generar Reportes"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/green"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <!-- Tarjeta de filtros - CORREGIDA -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Período del Reporte"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/green"
                    android:layout_marginBottom="16dp"/>

                <!-- Fecha Inicio -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fecha Inicio"
                    android:textSize="12sp"
                    android:textColor="@color/green"
                    android:layout_marginBottom="4dp"
                    android:layout_marginStart="4dp"/>

                <EditText
                    android:id="@+id/etFechaInicio"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="dd/mm/aaaa"
                    android:textSize="16sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:focusable="false"
                    android:clickable="true"
                    android:cursorVisible="false"
                    android:background="@drawable/edit_text_background"
                    android:layout_marginBottom="12dp"/>

                <!-- Fecha Fin -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fecha Fin"
                    android:textSize="12sp"
                    android:textColor="@color/green"
                    android:layout_marginBottom="4dp"
                    android:layout_marginStart="4dp"/>

                <EditText
                    android:id="@+id/etFechaFin"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="dd/mm/aaaa"
                    android:textSize="16sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:focusable="false"
                    android:clickable="true"
                    android:cursorVisible="false"
                    android:background="@drawable/edit_text_background"
                    android:layout_marginBottom="12dp"/>

                <!-- Tipo de Residuo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tipo de Residuo (Opcional)"
                    android:textSize="12sp"
                    android:textColor="@color/green"
                    android:layout_marginBottom="4dp"
                    android:layout_marginStart="4dp"/>

                <AutoCompleteTextView
                    android:id="@+id/actFiltroTipo"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Seleccione tipo"
                    android:textSize="16sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/edit_text_background"
                    android:dropDownVerticalOffset="8dp"
                    android:popupBackground="@drawable/rounded_dropdown_background"
                    android:inputType="none"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Opciones de formato - CORREGIDA -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Formato del Reporte"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/green"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <Button
                        android:id="@+id/btnGenerarPDF"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:text="PDF"
                        android:textSize="16sp"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="@color/green"/>

                    <Button
                        android:id="@+id/btnGenerarCSV"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:text="CSV"
                        android:textSize="16sp"
                        android:backgroundTint="@color/green"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Resultados - CORREGIDA -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardResultados"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reporte Generado"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/green"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvResultado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <Button
                        android:id="@+id/btnCompartir"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Compartir"
                        android:textSize="14sp"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="@color/green"/>

                    <Button
                        android:id="@+id/btnAbrir"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Abrir"
                        android:textSize="14sp"
                        android:backgroundTint="@color/green"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ProgressBar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="32dp"
            android:visibility="gone"/>

    </LinearLayout>

</ScrollView>